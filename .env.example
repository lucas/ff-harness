# OpenRouter API key — required. Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# Chat worker (bootstrap / brief / mockup / clarification stages)
MODEL_CHAT=deepseek/deepseek-v4-flash:free
MODEL_CHAT_FALLBACK=deepseek/deepseek-v4-flash

# Code worker (HTML/CSS/JS write_file stages)
MODEL_CODE=qwen/qwen3-coder:free
MODEL_CODE_FALLBACK=

# Optional: spend cap per day in USD (default 1.0)
# SPEND_CAP_USD=1.0

# Optional: turn cap before human approval gate (default 10)
# TURN_CAP=10
